# Server Configuration
# Back4app will automatically assign a PORT, but you can set a default here
PORT=5005
NODE_ENV=production

# Database Configuration
# Get your MongoDB connection string from MongoDB Atlas or similar
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database_name>

# Security
# Set a long random string for JWT
JWT_SECRET=your_jwt_secret_here

# External Services APIs (Required for core functionality)
# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# AssemblyAI API Key (for speech-to-text)
ASSEMBLY_AI_API_KEY=your_assembly_ai_api_key_here

# CORS Configuration
# Set this to your frontend URL after deploying the client
CLIENT_URL=http://localhost:5175
